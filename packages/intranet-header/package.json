    "@angular/router": "^21.1.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/cli": "^21.1.4",
    "@angular/compiler-cli": "^21.1.0",
    "typescript": "~5.9.2"
