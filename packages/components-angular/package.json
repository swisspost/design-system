{
  "name": "@swisspost/design-system-components-angular",
  "version": "10.0.0-next.73",
  "description": "Swiss Post Design System - Angular Wrapper Components",
  "author": "Swiss Post <design-system@post.ch>",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
