{
  "name": "@swisspost/design-system-components",
  "version": "10.0.0-next.75",
  "description": "A collection of web components built with Stencil JS for the Swiss Post Design System.",
  "author": "Swiss Post <design-system@post.ch>",
  "license": "Apache-2.0",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/swisspost/design-system"
  },
  "homepage": "https://design-system.post.ch",
  "bugs": {
    "url": "https://github.com/swisspost/design-system/issues"
  },
  "publishConfig": {
    "access": "public",
    "linkDirectory": true
  },
  "files": [
    "dist/",
    "hydrate/"
  ],
  "sideEffects": [
    "./dist/esm/post-components.js",
    "./dist/cjs/post-components.cjs.js",
    "./dist/components/index.js",
    "./dist/loader/index.js",
    "./dist/loader/index.cjs.js",
    "./cypress/**",
    "*.css"
  ],
  "type": "module",
  "main": "dist/index.cjs.js",
  "module": "dist/index.js",
  "types": "dist/types/index.d.ts",
  "collection": "dist/collection/collection-manifest.json",
  "collection:main": "dist/collection/index.js",
  "unpkg": "dist/post-components/post-components.esm.js",
  "exports": {
    "./package.json": "./package.json",
    "./post-components.css": "./dist/post-components/post-components.css",
    ".": {
      "types": "./dist/types/index.d.ts",
      "import": "./dist/esm/post-components.js",
      "default": "./dist/cjs/post-components.cjs.js"
    },
    "./dist/*": {
      "default": "./dist/*"
    },
    "./loader": {
      "types": "./dist/loader/index.d.ts",
      "import": "./dist/loader/index.js",
      "default": "./dist/loader/index.cjs.js"
    },
    "./components": {
      "types": "./dist/components/index.d.ts",
      "default": "./dist/components/index.js"
    },
    "./components/*": {
      "default": "./dist/components/*"
    },
    "./react": {
      "types": "./dist/components/react/index.d.ts",
      "default": "./dist/components/react/index.js"
    },
    "./react/*": {
      "default": "./dist/components/react/*"
    },
    "./hydrate": {
      "types": "./hydrate/index.d.ts",
      "node": {
        "import": "./hydrate/index.mjs",
        "default": "./hydrate/index.js"
      },
      "default": "./hydrate/index.stub.js"
    }
  },
  "scripts": {
    "play": "pnpm prebuild:script && stencil build --dev --port 9200 --serve --watch --config stencil.config.play.ts",
    "start": "pnpm prebuild:script && stencil build --dev --watch --docs --docs-readme",
    "prebuild": "pnpm clean && pnpm prebuild:script",
    "build": "stencil build --docs-readme",
    "postbuild": "pnpm copy:hydrate-stub & pnpm copy:component-names & pnpm copy:styles:components-react & pnpm copy:styles:components-angular",
    "clean": "rimraf --glob dist hydrate loader loaders www src/styles/generated src/_generated ../components-react/**/stencil-generated/ ../components-angular/projects/components/src/lib/stencil-generated/",
    "unit": "stencil test --spec",
    "unit:watch": "stencil test --spec --watchAll --silent",
    "unit:updatesnapshot": "stencil test --spec --updateSnapshot",
    "e2e": "cypress run --browser chrome",
    "e2e:watch": "cypress open",
    "e2e:ci": "xvfb-run -a cypress run --browser chrome",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "vrt": "node vrt/generate-header-html.js && playwright test",
    "vrt:update": "node vrt/generate-header-html.js && playwright test --update-snapshots",
    "vrt:ui": "node vrt/generate-header-html.js playwright test --ui",
    "vrt:chrome": "node vrt/generate-header-html.js && playwright test --project=chromium",
    "vrt:firefox": "node vrt/generate-header-html.js && playwright test --project=firefox",
    "vrt:safari": "node vrt/generate-header-html.js && playwright test --project=webkit",
    "generate": "stencil generate",
    "prebuild:script": "node --loader ts-node/esm prebuild.ts",
    "copy:hydrate-stub": "copyfiles -f src/hydrate-stub/* hydrate/",
    "copy:component-names": "copyfiles -f src/_generated/component-names.json dist/",
    "copy:styles:components-react": "copyfiles -f www/build/post-components.css ../components-react/src/stencil-generated/",
    "copy:styles:components-angular": "copyfiles -f www/build/post-components.css ../components-angular/projects/components/src/lib/stencil-generated/"
  },
  "dependencies": {
    "@floating-ui/dom": "1.7.6",
    "@oddbird/popover-polyfill": "0.6.0",
    "@stencil/core": "4.43.3",
    "@swisspost/design-system-icons": "workspace:10.0.0-next.75",
    "@swisspost/design-system-styles": "workspace:10.0.0-next.75",
    "air-datepicker": "3.6.0",
    "ally.js": "1.4.1",
    "imask": "7.6.1"
  },
  "devDependencies": {
    "@eslint/compat": "1.2.5",
    "@eslint/js": "9.18.0",
    "@percy/cli": "1.31.13",
    "@percy/cypress": "3.1.8",
    "@playwright/test": "catalog:",
    "@stencil-community/eslint-plugin": "0.10.0",
    "@stencil/angular-output-target": "1.1.1",
    "@stencil/react-output-target": "1.2.0",
    "@stencil/sass": "3.0.12",
    "@swisspost/design-system-eslint": "workspace:10.0.0-next.75",
    "@types/jest": "catalog:stencil/jest",
    "@types/node": "catalog:node",
    "@typescript-eslint/parser": "7.18.0",
    "copyfiles": "2.4.1",
    "cypress": "catalog:cypress",
    "cypress-axe": "catalog:cypress",
    "cypress-storybook": "catalog:cypress",
    "eslint": "9.26.0",
    "eslint-plugin-cypress": "4.2.0",
    "eslint-plugin-react": "7.37.5",
    "globals": "17.3.0",
    "http-server": "14.1.1",
    "jest": "catalog:stencil/jest",
    "jest-cli": "catalog:stencil/jest",
    "memfs": "4.51.0",
    "prettier": "3.6.2",
    "replace": "1.2.2",
    "rimraf": "6.0.1",
    "rollup-plugin-postcss": "4.0.2",
    "sass": "1.89.2",
    "throttle-debounce": "5.0.2",
    "ts-jest": "catalog:stencil/jest",
    "ts-node": "catalog:node",
    "typescript": "catalog:typescript",
    "typescript-eslint": "catalog:typescript"
  },
  "keywords": [
    "components",
    "web-components",
    "stencil",
    "design-system",
    "ui",
    "frontend"
  ]
}
