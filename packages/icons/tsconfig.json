{
  "extends": "@tsconfig/node24/tsconfig.json",
  "ts-node": {
    "transpileOnly": true,
    "files": true
  },
  "compilerOptions": {
    "rootDir": ".",
    "resolveJsonModule": true,
    "types": ["node", "jest"],
    "isolatedModules": true
  },
  "include": ["src", "tests"],
  "exclude": ["node_modules", "public"]
}
